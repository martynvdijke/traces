{
  "openapi": "3.0.0",
  "info": {
    "title": "TRACES API",
    "description": "A timeline API for managing events with multimedia (images, videos, audio) throughout the year.",
    "version": "1.8.8",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:6270",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/login": {
      "post": {
        "summary": "Login admin user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "Admin username"
                  },
                  "password": {
                    "type": "string",
                    "description": "Admin password"
                  },
                  "setup": {
                    "type": "boolean",
                    "description": "Set to true for initial setup"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/logout": {
      "post": {
        "summary": "Logout admin user",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Logout successful"
          }
        }
      }
    },
    "/api/events": {
      "get": {
        "summary": "Get timeline events",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2026"
            }
          },
          {
            "name": "month",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "01"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 10
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TimelineEvent"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create or update event",
        "tags": ["Events"],
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TimelineEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event saved"
          }
        }
      },
      "delete": {
        "summary": "Delete event",
        "tags": ["Events"],
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event deleted"
          }
        }
      }
    },
    "/api/events/search": {
      "get": {
        "summary": "Search events",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Search query"
          },
          {
            "name": "year",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "person",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "media_type",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "location",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "month",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TimelineEvent" }
                }
              }
            }
          }
        }
      }
    },
    "/api/events/full": {
      "get": {
        "summary": "Get all events with full fields",
        "tags": ["Events"],
        "responses": {
          "200": {
            "description": "All events with all fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TimelineEvent" }
                }
              }
            }
          }
        }
      }
    },
    "/api/events/export": {
      "get": {
        "summary": "Export events as JSON or CSV",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "format",
            "in": "query",
            "schema": { "type": "string", "enum": ["json", "csv"] }
          }
        ],
        "responses": {
          "200": { "description": "Exported events" }
        }
      }
    },
    "/api/events/clone": {
      "post": {
        "summary": "Clone an event to a new date",
        "tags": ["Events"],
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "date": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Event cloned" }
        }
      }
    },
    "/api/events/import": {
      "post": {
        "summary": "Import events from JSON or CSV",
        "tags": ["Events"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": { "description": "Events imported" }
        }
      }
    },
    "/api/contributions": {
      "get": {
        "summary": "Get contribution data for graph",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2026"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Map of date to event count",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/stats": {
      "get": {
        "summary": "Get event statistics",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Event statistics",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EventStats" }
              }
            }
          }
        }
      }
    },
    "/api/tags": {
      "get": {
        "summary": "Get all unique tags",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of tags",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/api/public": {
      "get": {
        "summary": "Get public events",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "share",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "year",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Public events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TimelineEvent" }
                }
              }
            }
          }
        }
      }
    },
    "/api/share": {
      "get": {
        "summary": "Access a share link",
        "tags": ["Sharing"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Redirect to shared view" }
        }
      }
    },
    "/api/share/create": {
      "post": {
        "summary": "Create a share link",
        "tags": ["Sharing"],
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event_ids": {
                    "type": "array",
                    "items": { "type": "integer" }
                  },
                  "year": { "type": "string" },
                  "days": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Share link created" }
        }
      }
    },
    "/api/map": {
      "get": {
        "summary": "Get events with map coordinates",
        "tags": ["Events"],
        "parameters": [
          { "name": "year", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "GeoJSON feature collection",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string" },
                    "features": { "type": "array" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/persons": {
      "get": {
        "summary": "List all persons",
        "tags": ["Persons"],
        "responses": {
          "200": {
            "description": "List of persons",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Person" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create or update a person",
        "tags": ["Persons"],
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Person" }
            }
          }
        },
        "responses": {
          "200": { "description": "Person saved" }
        }
      },
      "delete": {
        "summary": "Delete a person",
        "tags": ["Persons"],
        "security": [{ "SessionCookie": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Person deleted" }
        }
      }
    },
    "/api/persons/{id}/events": {
      "get": {
        "summary": "Get events for a person",
        "tags": ["Persons"],
        "security": [{ "SessionCookie": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Person events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TimelineEvent" }
                }
              }
            }
          }
        }
      }
    },
    "/api/autocomplete": {
      "get": {
        "summary": "Autocomplete suggestions",
        "tags": ["Events"],
        "parameters": [
          { "name": "field", "in": "query", "schema": { "type": "string", "enum": ["location", "person", "tag", "media"] } },
          { "name": "q", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Suggestions",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "/api/upload": {
      "post": {
        "summary": "Upload media file",
        "tags": ["Media"],
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": { "type": "string", "format": "binary" },
                  "video": { "type": "string", "format": "binary" },
                  "audio": { "type": "string", "format": "binary" },
                  "media_type": { "type": "string", "enum": ["image", "video", "audio"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": { "type": "string" },
                    "media_type": { "type": "string" },
                    "thumbnail": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/version": {
      "get": {
        "summary": "Get API version",
        "tags": ["Info"],
        "responses": {
          "200": {
            "description": "Version info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/check-setup": {
      "get": {
        "summary": "Check if admin is configured",
        "tags": ["Info"],
        "responses": {
          "200": {
            "description": "Setup status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "setup": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/gotify/config": {
      "get": {
        "summary": "Get Gotify configuration",
        "tags": ["Notifications"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Gotify config",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GotifyConfig" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Save Gotify configuration",
        "tags": ["Notifications"],
        "security": [{ "SessionCookie": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GotifyConfig" }
            }
          }
        },
        "responses": {
          "200": { "description": "Config saved" }
        }
      }
    },
    "/api/gotify/test": {
      "post": {
        "summary": "Send a test Gotify notification",
        "tags": ["Notifications"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": { "description": "Test notification sent" }
        }
      }
    },
    "/api/memories": {
      "get": {
        "summary": "Get memory events",
        "tags": ["Memories"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Memory events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TimelineEvent" }
                }
              }
            }
          }
        }
      }
    },
    "/api/memories/config": {
      "get": {
        "summary": "Get memories settings",
        "tags": ["Memories"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Memories config",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemoriesConfig" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Save memories settings",
        "tags": ["Memories"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": { "description": "Config saved" }
        }
      }
    },
    "/api/memories/send": {
      "post": {
        "summary": "Send memories email",
        "tags": ["Memories"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": { "description": "Email sent" }
        }
      }
    },
    "/api/email/config": {
      "get": {
        "summary": "Get email settings",
        "tags": ["Email"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": {
            "description": "Email config",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EmailConfig" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Save email settings",
        "tags": ["Email"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": { "description": "Config saved" }
        }
      }
    },
    "/api/email/test": {
      "post": {
        "summary": "Send a test email",
        "tags": ["Email"],
        "security": [{ "SessionCookie": [] }],
        "responses": {
          "200": { "description": "Test email sent" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TimelineEvent": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "location": { "type": "string" },
          "latitude": { "type": "number", "format": "float" },
          "longitude": { "type": "number", "format": "float" },
          "media_type": { "type": "string", "enum": ["image", "video", "audio"] },
          "media_url": { "type": "string" },
          "thumbnail": { "type": "string" },
          "media_caption": { "type": "string" },
          "tags": { "type": "string" },
          "sort_order": { "type": "integer" },
          "is_public": { "type": "boolean" },
          "person_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "avatar_url": { "type": "string" },
          "bio": { "type": "string" },
          "birth_date": { "type": "string", "format": "date" },
          "color": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "GotifyConfig": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "token": { "type": "string" },
          "enabled": { "type": "boolean" }
        }
      },
      "EventStats": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "by_month": { "type": "object" },
          "by_tag": { "type": "object" },
          "by_media": { "type": "object" },
          "locations": { "type": "integer" },
          "with_media": { "type": "integer" },
          "with_geo": { "type": "integer" },
          "by_year": { "type": "object" },
          "total_years": { "type": "integer" },
          "person_count": { "type": "integer" }
        }
      },
      "MemoriesConfig": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "days_window": { "type": "integer" },
          "email_enabled": { "type": "boolean" }
        }
      },
      "EmailConfig": {
        "type": "object",
        "properties": {
          "smtp_host": { "type": "string" },
          "smtp_port": { "type": "integer" },
          "smtp_user": { "type": "string" },
          "smtp_pass": { "type": "string" },
          "from_addr": { "type": "string" },
          "to_addr": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "SessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session"
      }
    }
  }
}
