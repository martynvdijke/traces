{
  "openapi": "3.0.0",
  "info": {
    "title": "TRACES API",
    "description": "A timeline API for managing events with multimedia (images, videos, audio) throughout the year.",
    "version": "1.1.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/login": {
      "post": {
        "summary": "Login admin user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "Admin username"
                  },
                  "password": {
                    "type": "string",
                    "description": "Admin password"
                  },
                  "setup": {
                    "type": "boolean",
                    "description": "Set to true for initial setup"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/logout": {
      "post": {
        "summary": "Logout admin user",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Logout successful"
          }
        }
      }
    },
    "/api/events": {
      "get": {
        "summary": "Get timeline events",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2026"
            }
          },
          {
            "name": "month",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "01"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TimelineEvent"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create or update event",
        "tags": ["Events"],
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TimelineEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event saved"
          }
        }
      },
      "delete": {
        "summary": "Delete event",
        "tags": ["Events"],
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event deleted"
          }
        }
      }
    },
    "/api/contributions": {
      "get": {
        "summary": "Get contribution data for graph",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2026"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Map of date to event count",
            "content": {
              "application/json": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer"
                }
              }
            }
          }
        }
      }
    },
    "/api/upload": {
      "post": {
        "summary": "Upload media file",
        "tags": ["Media"],
        "security": [
          {
            "SessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "video": {
                    "type": "string",
                    "format": "binary"
                  },
                  "audio": {
                    "type": "string",
                    "format": "binary"
                  },
                  "media_type": {
                    "type": "string",
                    "enum": ["image", "video", "audio"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    },
                    "media_type": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/version": {
      "get": {
        "summary": "Get API version",
        "tags": ["Info"],
        "responses": {
          "200": {
            "description": "Version info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/check-setup": {
      "get": {
        "summary": "Check if admin is configured",
        "tags": ["Info"],
        "responses": {
          "200": {
            "description": "Setup status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "setup": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TimelineEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "location": {
            "type": "string"
          },
          "media_type": {
            "type": "string",
            "enum": ["image", "video", "audio"]
          },
          "media_url": {
            "type": "string"
          },
          "thumbnail": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "SessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session"
      }
    }
  }
}