{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./static",
    "rootDir": "./static",
    "declaration": false,
    "moduleResolution": "bundler"
  },
  "include": ["static/app.ts"],
  "exclude": ["node_modules"]
}